{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite-plugin-pwa/client", "vite-plugin-pwa/info", "vite-plugin-comlink/client"],
    "jsx": "react-jsx",
    "checkJs": true,
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/tsc/ui",
    "tsBuildInfoFile": "./node_modules/.cache/tsc/ui.tsbuildinfo"
  },
  "include": ["src", "test", "src/data/**/*.json"],
  "exclude": ["src/sw.ts", "src/serviceWorker", "src/core", "src/core/types.ts"],
  "references": [{ "path": "./tsconfig.core.json" }]
}
