{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["node"],
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/tsc/node",
    "tsBuildInfoFile": "./node_modules/.cache/tsc/node.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "nitro.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "server",
    "scripts",
    "lib",
    "src/vite-env.d.ts"
  ]
}
