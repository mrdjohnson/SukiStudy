{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "webworker"],
    "libReplacement": true,
    "types": [
      "vite-plugin-pwa/client",
      "vite-plugin-pwa/info",
      "vite-plugin-comlink/client",
      "@types/serviceworker"
    ],
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/tsc/sw",
    "tsBuildInfoFile": "./node_modules/.cache/tsc/sw.tsbuildinfo"
  },
  "include": ["src/sw.ts", "src/serviceWorker"],
  "references": [{ "path": "./tsconfig.core.json" }]
}
